rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model designed for a resume-building and 
     * subscription-based application. Access is partitioned by the authenticated user's UID.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Main user document storage
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);

      // Subcollections as defined in backend.json for structured data
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Publicly readable subscription plans
    match /subscription_plans/{planId} {
      allow get, list: if true;
      allow write: if false;
    }
  }
}
